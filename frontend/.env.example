VITE_API_BASE_URL=http://localhost:8080

# OpenRouter API key for AI features
VITE_OPENROUTER_API_KEY=

# Base model for chat and description generation
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional backend proxy for LLM requests.
# If specified, frontend will send AI requests there instead of calling OpenRouter directly.
VITE_LLM_PROXY_URL=
